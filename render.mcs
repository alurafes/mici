// an example of a system
system render {
    size_t count;
};
use component "position.mcc";
use component "rotation.mcc";

{
    void test()
    {
        printf("test\n");
    }
}

initialize
{

}

destroy
{

}

pre_update
{
    self->count = 0;
}

update
{
    self->count += 1;
}

post_update
{
    printf("%zu\n", self->count);
}